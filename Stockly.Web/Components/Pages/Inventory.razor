@page "/inventory"

<AppTitle Title="Lagerlista" />

@if (Products is null || Products.Count == 0)
{
    <p>Det finns inga produkter i lager.</p>
}
else
{
    <div class="row mb-3">
        <div class="col">
            <KPICard Text="Artiklar i sortiment" KeyPerformanceValue="0" SmallText="st"Color="BootstrapColor.Success" Icon="@BootstrapIcons.BoxSeam" />
        </div>
        <div class="col">
            <KPICard Text="Totalt lagervärde" KeyPerformanceValue="0" Color="BootstrapColor.Success" Icon="@BootstrapIcons.Coin" />
        </div>
        <div class="col">
            <KPICard Text="Lågt lagersaldo" KeyPerformanceValue="0" SmallText="st" Color="BootstrapColor.Danger" Icon="@BootstrapIcons.ExclamationTriangle" />
        </div>
    </div>
    <table class="table table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Art.nr</th>
                <th>Namn</th>
                <th>Kategori</th>
                <th>Saldo</th>
                <th>Pris</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Products)
            {
                <tr>
                    <td>@product.SKU</td>
                    <td>@product.Name</td>
                    <td>@product.Category</td>
                    <td>@product.Quantity</td>
                    <td>@product.Price.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}